PUBLIC_PORT=8080
NEXT_PUBLIC_SITE_URL=http://localhost:8080
API_PROXY_TARGET=http://backend:4000

# Production VPS values should be rotated before deployment.
# Example production overrides:
# NEXT_PUBLIC_SITE_URL=https://www.nourmed.org
# CORS_ALLOWED_ORIGINS=https://www.nourmed.org,https://nourmed.org

POSTGRES_DB=nourmed
POSTGRES_USER=nourmed_app
POSTGRES_PASSWORD=change-me-strong-postgres-password
DATABASE_URL=postgresql://nourmed_app:change-me-strong-postgres-password@db:5432/nourmed?schema=public

CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000
REQUEST_BODY_LIMIT=16kb
CONTACT_RATE_LIMIT_WINDOW_MS=900000
CONTACT_RATE_LIMIT_MAX=5
PAYMENTS_RATE_LIMIT_WINDOW_MS=900000
PAYMENTS_RATE_LIMIT_MAX=10
SCAN_RATE_LIMIT_WINDOW_MS=1800000
SCAN_RATE_LIMIT_MAX=5
ADMIN_API_TOKEN=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=charmarke.nourmed@gmail.com
# Gmail requires 2-Step Verification and an App Password here, not the normal account password.
SMTP_PASS=
SMTP_FROM=charmarke.nourmed@gmail.com
LEAD_NOTIFICATION_TO=charmarke.nourmed@gmail.com
STRIPE_SECRET_KEY=
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
SCAN_HTTP_TIMEOUT_MS=10000
SCAN_MAX_RESPONSE_BYTES=262144
SCAN_ALLOW_PRIVATE_TARGETS=false
SCAN_USER_AGENT=NourmedAuthorizedSecurityReview/1.0 (+https://www.nourmed.org)
TRUST_PROXY=1
LOG_LEVEL=info
SHUTDOWN_TIMEOUT_MS=10000
LETSENCRYPT_EMAIL=security@nourmed.org

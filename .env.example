PUBLIC_PORT=8080
NEXT_PUBLIC_SITE_URL=http://localhost:8080

# Production VPS values should be rotated before deployment.
# Example production overrides:
# NEXT_PUBLIC_SITE_URL=https://www.nourmed.org
# CORS_ALLOWED_ORIGINS=https://www.nourmed.org,https://nourmed.org

POSTGRES_DB=nourmed
POSTGRES_USER=nourmed_app
POSTGRES_PASSWORD=change-me-strong-postgres-password
DATABASE_URL=postgresql://nourmed_app:change-me-strong-postgres-password@db:5432/nourmed?schema=public

CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000
REQUEST_BODY_LIMIT=16kb
CONTACT_RATE_LIMIT_WINDOW_MS=900000
CONTACT_RATE_LIMIT_MAX=5
TRUST_PROXY=1
LOG_LEVEL=info
SHUTDOWN_TIMEOUT_MS=10000
LETSENCRYPT_EMAIL=security@nourmed.org
